      "dark": "red",
      "light": "red"
    },
    "diffContext": {
      "dark": "dark5",
      "light": "dark3"
    },
    "diffHunkHeader": {
      "dark": "dark3",
      "light": "dark5"
    },
    "diffHighlightAdded": {
      "dark": "green1",
      "light": "green1"
    },
    "diffHighlightRemoved": {
      "dark": "red1",
      "light": "red1"
    },
    "diffAddedBg": {
      "dark": "#203234",
      "light": "#c7e5c8"
    },
    "diffRemovedBg": {
      "dark": "#34242a",
      "light": "#f5c6cb"
    },
    "diffContextBg": {
      "dark": "bg_dark",
      "light": "fg_dark"
