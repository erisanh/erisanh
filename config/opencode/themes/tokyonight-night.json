  "theme": {
    "primary": {
      "dark": "blue",
      "light": "blue"
    },
    "secondary": {
      "dark": "purple",
      "light": "purple"
    },
    "accent": {
      "dark": "cyan",
      "light": "cyan"
    },
    "error": {
      "dark": "red",
      "light": "red"
    },
    "warning": {
      "dark": "orange",
      "light": "orange"
    },
    "success": {
      "dark": "green",
      "light": "green"
    },
    "info": {
      "dark": "blue2",
      "light": "blue2"
    },
    "text": {
      "dark": "fg",
      "light": "bg_dark1"
    },
    "textMuted": {
      "dark": "dark5",
      "light": "dark3"
    },
    "background": {
      "dark": "bg",
      "light": "fg"
    },
    "backgroundPanel": {
      "dark": "bg_dark",
      "light": "fg_dark"
    },
    "backgroundElement": {
      "dark": "bg_highlight",
      "light": "fg_dark"
    },
    "border": {
      "dark": "terminal_black",
      "light": "dark3"
