{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg": "#1a1b26",
    "bg_dark": "#16161e",
    "bg_dark1": "#0C0E14",
    "bg_highlight": "#292e42",
    "blue": "#7aa2f7",
    "blue0": "#3d59a1",
    "blue1": "#2ac3de",
    "blue2": "#0db9d7",
    "blue5": "#89ddff",
    "blue6": "#b4f9f8",
    "blue7": "#394b70",
    "comment": "#565f89",
    "cyan": "#7dcfff",
    "dark3": "#545c7e",
    "dark5": "#737aa2",
    "fg": "#c0caf5",
    "fg_dark": "#a9b1d6",
    "fg_gutter": "#3b4261",
    "green": "#9ece6a",
    "green1": "#73daca",
    "green2": "#41a6b5",
    "magenta": "#bb9af7",
    "magenta2": "#ff007c",
    "orange": "#ff9e64",
    "purple": "#9d7cd8",
    "red": "#f7768e",
    "red1": "#db4b4b",
    "teal": "#1abc9c",
    "terminal_black": "#414868",
    "yellow": "#e0af68"
