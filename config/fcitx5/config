# fcitx5 global config — managed by this dotfiles repo.
# Vietnamese (Bamboo) ⇄ English, toggled with Super+Space.
# NOTE: Super+Space is intentionally NOT bound in Hyprland (the app launcher
# moved to Super+A) so fcitx5 can use it as the input-method toggle.

[Hotkey]
# Enumerate input methods when the trigger key is pressed repeatedly
EnumerateWithTriggerKeys=True
# Do not skip the first (English) method while enumerating
EnumerateSkipFirst=False

[Hotkey/TriggerKeys]
0=Super+space

[Behavior]
# Start in English; press Super+Space to switch to Vietnamese
ActiveByDefault=False
# Share the on/off state across all programs
ShareInputState=All
PreeditEnabledByDefault=True
