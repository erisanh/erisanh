#!/usr/bin/env bash
#
# Quake-style terminal toggle for Hyprland (Lua/0.55+ dispatcher syntax).
# All hyprctl dispatch calls use hl.dsp.* Lua expressions, which is required
# since Hyprland now evaluates dispatch arguments as Lua.

WORKSPACE=$(hyprctl clients -j | jq -rec '.[] | select(.class == "dai.quake") | .workspace.name')

echo "WORKSPACE: $WORKSPACE"

if [ -z "$WORKSPACE" ]; then
  echo "start"
  # Save the current active window so HIDE can restore focus to it later
  hyprctl activewindow | head -n1 | cut -f2 -d ' ' >/tmp/hypr-quake-address
  hyprctl dispatch 'hl.dsp.exec_cmd("ghostty --class=dai.quake")'

elif [ "$WORKSPACE" == "special:quake" ]; then
  echo "show"

  # Store the current active window address before switching to quake
  hyprctl activewindow | head -n1 | cut -f2 -d ' ' >/tmp/hypr-quake-address

  # If the current active window is fullscreen, unfullscreen it first
  hyprctl activewindow | rg "fullscreen: 1" && \
    hyprctl dispatch 'hl.dsp.window.fullscreen_state({ internal = 0, client = 0 })'

  # Move the quake window to the current workspace, focus it, and bring it to the top
  CUR_WS=$(hyprctl activeworkspace -j | jq -r '.id')
  hyprctl dispatch "hl.dsp.window.move({ workspace = $CUR_WS, window = \"class:^(dai\\\\.quake)$\" })"
  hyprctl dispatch 'hl.dsp.focus({ window = "class:^(dai\\.quake)$" })'
  hyprctl dispatch 'hl.dsp.window.bring_to_top()'

else
  echo "hide"

  # Move the quake window to the special workspace
  hyprctl dispatch 'hl.dsp.window.move({ workspace = "special:quake", window = "class:^(dai\\.quake)$" })'

  # Focus the previously active window and bring it to the top
  ADDR=$(cat /tmp/hypr-quake-address 2>/dev/null)
  [ -n "$ADDR" ] && hyprctl dispatch "hl.dsp.focus({ window = \"address:0x$ADDR\" })"
  hyprctl dispatch 'hl.dsp.window.bring_to_top()'
fi
