# cava — audio visualizer (plan.theme.md §3)
# Theme: background #0f120e, accent gradient blue -> purple (matches desktop).
# Lightweight: 30 fps + sleeps when audio is silent (no idle CPU).

[general]
framerate = 30
# auto bar count to fill the terminal
bars = 0
bar_width = 2
bar_spacing = 1
autosens = 1
# go to sleep after 5s of silence -> 0 idle CPU until sound returns
sleep_timer = 5

[input]
method = pipewire
source = auto

[output]
method = ncurses
channels = stereo
mono_option = average
# blocks look nicer than the default for a slim bar
ascii_max_range = 100

[color]
background = '#0f120e'
gradient = 1
gradient_count = 5
gradient_color_1 = '#004C6E'
gradient_color_2 = '#95CDF7'
gradient_color_3 = '#B7C9D9'
gradient_color_4 = '#CEC0E8'
gradient_color_5 = '#DD5C82'

[smoothing]
noise_reduction = 0.55
