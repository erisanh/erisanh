	"Go Repository Snippet": {
		"prefix": "gorepository",
		"body": [
			"package repositories",
			"",
			"import (",
			"  \"errors\"",
			"",
			"  \"github.com/tripc/tripc-server/models\"",
			"  \"github.com/tripc/tripc-server/transaction\"",
			"  \"gorm.io/gorm\"",
			")",
			"",
			"type ${1:ModelName}QueryAttrs struct {",
			"  // Define query attributes here, e.g.",
			"  Keyword *string `structs:\"keyword\"`",
			"}",
			"",
			"type ${1:ModelName}Repository interface {",
			"  List(attrs *${1:ModelName}QueryAttrs, paging *Paging) ([]*models.${1:ModelName}, int64, error)",
			"}",
			"",
			"type ${2:modelName}Repository struct {",
			"  tm *transaction.TransactionManager",
			"}",
			"",
			"func New${1:ModelName}Repository(tm *transaction.TransactionManager) ${1:ModelName}Repository {",
			"  return &${2:modelName}Repository{tm: tm}",
			"}",
			"",
			"func (r *${2:modelName}Repository) List(attrs *${1:ModelName}QueryAttrs, paging *Paging) ([]*models.${1:ModelName}, int64, error) {",
			"  var models []*models.${1:ModelName}",
			"  var totalRows int64",
			"",
			"  query := r.tm.DB().Model(&models.${1:ModelName}{})",
			"",
			"  if attrs.Keyword != nil && *attrs.Keyword != \"\" {",
			"    query = query.Where(\"name ILIKE ?\", \"%\"+*attrs.Keyword+\"%\")",
			"  }",
			"",
			"  if err := query.Count(&totalRows).Error; err != nil {",
			"    return nil, 0, err",
			"  }",
			"",
			"  query = query.Offset(paging.Offset).Limit(paging.Limit)",
			"",
			"  if err := query.Find(&models).Error; err != nil {",
			"    return nil, 0, err",
			"  }",
			"",
			"  return models, totalRows, nil",
			"}"
		],
		"description": "Go repository template with transaction manager and GORM for List function"
	},
