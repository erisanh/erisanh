			"}",
			"",
			"func New${1:ModelName}Service(",
			"  tm *transaction.TransactionManager,",
			"  logger *zap.Logger,",
			"  repo repositories.${1:ModelName}Repository,",
			") *${1:ModelName}Service {",
			"  return &${1:ModelName}Service{",
			"    tm:     tm,",
			"    logger: logger,",
			"    repo:   repo,",
			"  }",
			"}"
		],
		"description": "Go service template with transaction manager, logger, and repository for List function"
