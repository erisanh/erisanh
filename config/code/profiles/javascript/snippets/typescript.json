{
	"NestJS Query DTO": {
		"prefix": "nest-query-dto",
		"body": [
			"import { IsString } from 'class-validator';",
			"",
			"import { PageOptionsDto } from '@app/common/dtos';",
			"",
			"export class ${1:EntityName}QueryDto extends PageOptionsDto {",
			"  @IsString()",
			"  ${2:fieldName}: string;",
			"  $0",
			"}"
		],
		"description": "Creates a NestJS Query DTO with pagination and required string filter"
	},
	"NestJS Entity DTO": {
		"prefix": "nest-entity-dto",
		"body": [
			"import { ApiProperty, ApiPropertyOptional } from '@nestjs/swagger';",
			"import { Expose } from 'class-transformer';",
			"import { IsNotEmpty, IsOptional, IsString, IsNumber, IsBoolean } from 'class-validator';",
			"",
			"export class ${1:Entity}Dto {",
			"  @ApiProperty({ example: 1, description: '${1:Entity} ID' })",
			"  @Expose()",
			"  id: number;",
			"",
			"  @ApiProperty({ example: '${1:Entity} name', description: '${1:Entity} name' })",
			"  @IsNotEmpty()",
			"  @IsString()",
			"  @Expose()",
			"  name: string;",
			"",
			"  @ApiPropertyOptional({ example: '${2:optional-value}', description: '${3:Optional field description}' })",
			"  @IsOptional()",
			"  @IsString()",
			"  @Expose()",
			"  ${4:optionalField}?: string;",
			"  $0",
			"}"
		],
		"description": "Creates a NestJS Entity DTO with Swagger decorators"
	},
	"NestJS DTO Field": {
		"prefix": "nest-dto-field",
		"body": [
			"@${1|ApiProperty,ApiPropertyOptional|}({ example: ${2:'example'}, description: '${3:Field description}' })",
			"@${4|IsNotEmpty,IsOptional|}()",
			"@${5|IsString,IsNumber,IsBoolean,IsEnum,IsDate,IsArray|}(${6:})",
			"@Expose()",
			"${7:fieldName}${8|: string,: number,: boolean,?: string,?: number,?: boolean|};$0"
		],
		"description": "Adds a field to a NestJS DTO with proper decorators"
	}
}